[selenium_hub]
selenium-hub-1 ansible_host=REPLACE_WITH_HUB_IP ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/qa-staging-key.pem

[selenium_nodes]
selenium-node-1 ansible_host=REPLACE_WITH_NODE1_IP ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/qa-staging-key.pem
selenium-node-2 ansible_host=REPLACE_WITH_NODE2_IP ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/qa-staging-key.pem

[test_runner]
test-runner-1 ansible_host=REPLACE_WITH_RUNNER_IP ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/qa-staging-key.pem

[all:vars]
ansible_python_interpreter=/usr/bin/python3
environment=staging
