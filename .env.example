# Copy this file to .env and fill in your values
# Never commit .env to version control

# Selenium Grid
SELENIUM_HUB_URL=http://localhost:4444

# Application URLs
LOCAL_BASE_URL=http://localhost:8080
LOCAL_API_URL=http://localhost:8080/api/v1
STAGING_BASE_URL=https://staging.example.com
STAGING_API_URL=https://staging.example.com/api/v1
PRODUCTION_BASE_URL=https://app.example.com
PRODUCTION_API_URL=https://app.example.com/api/v1

# AWS (for Terraform)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# Terraform state bucket
TF_STATE_BUCKET=your-terraform-state-bucket

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
